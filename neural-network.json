put, hidden and output layers etc.). It is trained on the weights and the biases, which are the parameters of the network.","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"Yds38RU71u"}],"key":"npi5ce4XbB"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/image2-acda4ee950016ff16ba89045f30fdefd.gif","alt":"Neural Networks can be used to reasonably approriximate most functions","data":{"altTextIsAutoGenerated":true},"key":"t0pZdIOmYQ","urlSource":"images/image2.gif"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"captionNumber","kind":"figure","label":"image2","identifier":"image2","html_id":"image2","enumerator":"1","children":[{"type":"text","value":"Figure ","key":"WOw767tR49"},{"type":"text","value":"1","key":"DMzieoyYeT"},{"type":"text","value":":","key":"H0ABSrvZX4"}],"template":"Figure %s:","key":"yhPLN7dovW"},{"type":"text","value":"Neural Networks can be used to ","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"OltRJXKTz7"},{"type":"emphasis","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"reasonably","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"As91OkteRs"}],"key":"ON6SrlkkC4"},{"type":"text","value":" approriximate ","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"otuoKFNiCl"},{"type":"emphasis","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"most","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"HNMGLfi8Va"}],"key":"gGoO1nbzal"},{"type":"text","value":" functions","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"PZeuvPnVxN"}],"key":"wI0Pmy8nM8"}],"key":"y7KlvLqsSc"}],"label":"image2","identifier":"image2","enumerator":"2","html_id":"image2","key":"jxPnFU4JNc"},{"type":"heading","depth":2,"position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"text","value":"Feed forward","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"key":"MAZzzTIXPc"}],"identifier":"feed-forward","label":"Feed forward","html_id":"feed-forward","implicit":true,"key":"EDBryc7SZ6"},{"type":"paragraph","position":{"start":{"line":75,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"In artificial neural networks, the output from one layer is used as input to the next layer. Such networks are called feedforward neural networks.\nFeed forward neural network architecture consists of following main parts – Input Layer, Hidden Layer - If the number of hidden layer is one then it is known as a shallow neural network, else it is known as a deep neural network, Output Layer","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"LrcJd0jV0N"}],"key":"IRBWYqbC6M"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/image3-c38f21bb8ed8ec235f9b2be3ab3dd493.gif","alt":"📖Source","data":{"altTextIsAutoGenerated":true},"key":"rzpwUltGQH","urlSource":"images/image3.gif"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"captionNumber","kind":"figure","label":"image3","identifier":"image3","html_id":"image3","enumerator":"2","children":[{"type":"text","value":"Figure ","key":"BQxi3Uw1N0"},{"type":"text","value":"2","key":"JUgVK0HvQr"},{"type":"text","value":":","key":"NJmrN8L3sU"}],"template":"Figure %s:","key":"ahqTQX16uI"},{"type":"link","url":"https://machinelearningknowledge.ai/animated-explanation-of-feed-forward-neural-network-architecture/","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"📖Source","position":{"start":{"line":83,"column":1},