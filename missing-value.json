n a medical study, if a particular diagnostic causes discomfort, then there is higher chance of drop out from the study. This missing value is not at random unless we have included “discomfort” as an input variable for all patients.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"QkH1t9zclu"}],"key":"vp1ClLqK7g"}],"key":"mL4ZWkUI6e"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Missing that depends on the missing value itself:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"KCQgYu3hk9"}],"key":"XKgarYBrT5"},{"type":"text","value":" This is a case when the probability of missing value is directly correlated with missing value itself. For example: People with higher or lower income are likely to provide non-response to their earning.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"jjVTnN67s7"}],"key":"XMMlwXMzu6"}],"key":"d8EmbXOFxS"}],"key":"qUNKijh9Sh"}],"key":"FnJ1Fc4Vop"}],"key":"J9pw4uPZoA"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"There are many standard practices of dealing with missing data-","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"a9YwuGnCpp"}],"key":"QGd1IeQfk2"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":23,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Deletion:","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"IQ1h8KEsSh"}],"key":"ss91V2pg61"},{"type":"text","value":"  It is of two types: ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"SvhTZfl6ZP"},{"type":"emphasis","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"List Wise Deletion","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"Vw4kWIOQ3o"}],"key":"XvkxMt7Rzw"},{"type":"text","value":" and ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"FWAbsv9gpA"},{"type":"emphasis","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Pair Wise Deletion","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"rEib21Pxx2"}],"key":"bImiSAbHxT"},{"type":"text","value":".\nIn list wise deletion, we delete observations where any of the variable is missing. Simplicity is one of the major advantage of this method, but this method reduces the power of model because it reduces the sample size.\nIn pair wise deletion, we perform analysis with all cases in which the variables of interest are present. Advantage of this method is, it keeps as many cases available for analysis. One of the disadvantage of this method, it uses different sample size for different variables.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"sLpGBOfcZw"}],"key":"yoTUitYwvj"}],"key":"affLf1KFZ7"}],"key":"bUHKKxEQz2"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Deletion methods are used when the nature of missing data is “Missing completely at random” else non random missing values can bias the model output.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"BbBQx1EwEI"}],"key":"BhGDNAqBuM"}],"key":"Jnbiwp7ZX6"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":29,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":29,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"strong","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"Mean/ Mode/ Median Imputation:","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"xnZs3Apcqj"}],"key":"AJDJCpNU9u"},{"type":"text","value":" Imputation is a method to fill in the missing values with estimated ones. The objective is to employ known relationships that can be identified in the valid values of the data set to assist in estimating the missing values. Mean/Mode/Median imputation is one of the most frequently used methods. It consists of replacing the missing data for a given attribute by the mean or median (quantitative attribute) or mode (qualitative attribute) of all known values of that variable. It can be of two types:-","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"c6UZzV2XY5"}],"key":"dAKMsQva2m"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":30,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Generalized Imputation:","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"wPtYm45pEG"}],"key":"U20EMxqnpY"},{"type":"text","value":" In this case, we calculate the mean or median for all non missing values of that variable then replace missing value with mean or median.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"bi0kbSifOO"}],"key":"A95uaSNOO1"}],"key":"kEylTSjViy"},{"type":"listItem","spread":true,"position":{"start":{"line":31,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Similar case Imputation:","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"q9Mzz4s5ZQ"}],"key":"UUC8wyGSjE"},{"type":"text","value":" In this case, for example, we calculate average for gender “Male” (29.75) and “Female” (25) individually of non missing values then replace the missing value based on gender. For “Male“, we will replace missing values of manpower with 29.75 and for “Female” with 25.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"fj1rKwGIA2"}],"key":"TF5eJX2ola"}],"key":"KNV3iGDyvB"}],"key":"J6mGAgL40D"}],"key":"UID4MRB2Fv"},{"type":"listItem","spread":true,"position":{"start":{"line":33,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"strong","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Prediction Model:","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"R4zNr4rX3x"}],"key":"WrJgOirTSN"},{"type":"text","value":"  Prediction model is one of the sophisticated method for handling missing data. Here, we create a predictive model to estimate values that will substitute the missing data.  In this case, we divide our data set into two sets: One set with no missing values for the variable and another one with missing values. First data set become training data set of the model while second data set with missing values is test data set and variable with missing values is treated as target variable. Next, we create a model to predict target variable based on other attributes of the training data set and populate missing values of test data set.We can use regression, ANOVA, Logistic regression and various modeling technique to perform this. There are 2 drawbacks for this approach:","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"bTbPCU6zmN"}],"key":"rElzkWHfk6"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":34,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The model estimated values are usually more well-behaved than the true values","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"Cau5GW3siL"}],"key":"LaVzQCgg4Y"}],"key":"pe19TqQs5x"},{"type":"listItem","spread":true,"position":{"start":{"line":35,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If there are no relationships with attributes in the data set and the attribute with missing values, then the model will not be precise for estimating missing values","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"DOvh9MJtQp"}],"key":"yBwfYgoYHN"}],"key":"K143C58qMx"}],"key":"nGba1rngo2"}],"key":"EjMZ2NsyCx"},{"type":"listItem","spread":true,"position":{"start":{"line":37,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"strong","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"KNN Imputation:","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"NrX5t98vpx"}],"key":"Mx0Al6DzEE"},{"type":"text","value":