,{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"You have an array of integers of length n spanning 0 to n with one missing. Write a function that returns the missing number in the array","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"wT8pnrEu2m"}],"key":"Dj87f3WppE"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"JCdS9LflRD"}],"key":"oBDZmQZdUf"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"nums = [0,1,2,4,5]\nmissingNumber(nums) -> 3\nComplexity of O(N) required.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"pM3YVNPCxt"}],"key":"ST7p2aDnL1"}],"class":"dropdown, tip","key":"RH37Ote182"}],"key":"yJ7OeNiUFD"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"nums = [0,1,2,4,5]\n\nfor i in range(0,len(nums)-1):\n    if(nums[i+1]-nums[i]>1):\n        print(nums[i]+1)        ","visibility":"show","key":"APzC7KN3lb"},{"type":"outputs","id":"Sf3qmxPTvygT0BBUNDKpK","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"3\n"},"children":[],"key":"m49ZTtHfHC"}],"visibility":"show","key":"yJ5G4vJeXI"}],"visibility":"hide","key":"aOYEO1uSs6"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Problem: [SQUARE] Book Combinations","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GZm4HFSdPP"}],"key":"lVgUR9qAZs"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"You have store credit of N dollars. However, you don’t want to walk a long distance with heavy books, but you want to spend all of your store credit.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"PTaeiHGEAA"}],"key":"saRJxwKM5I"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Let’s say we have a list of books in the format of tuples where the first value is the price and the second value is the weight of the book -> (price,weight).","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"vAluxCHHtp"}],"key":"wLBmYqRG0l"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Write a function optimal_books to retrieve the combination allows you to spend all of your store credit while getting at least two books at the lowest weight.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"ygSz0Psnrx"}],"key":"rTOQ9vFzHe"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Note: you should spend all your credit and getting at least 2 books, If no such condition satisfied just return empty list.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"BmIfPFn2dU"}],"key":"OdpzGRiK1v"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"MHfLOxGWIR"}],"key":"HSxYJCKZAY"},{"type":"code","lang":"","value":"N = 18\nbooks = [(17,8), (9,4), (18,5), (11,9), (1,2), (13,7), (7,5), (3,6), (10,8)]\n\ndef optimal_books(N, books) -> [(17,8),(1,2)]","position":{"start":{"line":14,"column":1},"end":{"line":17,"column":1}},"key":"zwcdjf7ESG"}],"class":"dropdown, tip","key":"ZwZPoJ0tEy"}],"key":"w8GkZYwsRl"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# Let's take this step by step\nimport itertools\n\ndef optimal_books(N, books):\n    print(\"(Price,Weight) details of books: \",books)\n    print(\"Store Credit: \",N)\n    final_books = [] # empty list to store the final books\n    # sorting the books by weight as we need the lightest books\n    sorted_books = sorted(books, key = lambda x:x[1]) \n    price = [i[0] for i in sorted_books] #list of prices sorted by weight\n    \n    for i in range(2,len(price)+1):\n        templist = (list(itertools.combinations(price,i))) # generating all combinations of price\n        res = [sum(j) for j in templist] # summing individual combination to get total price of each combination\n        if N in res: # if the result matches traceback traceback and append the combination         \n            tempbooks = (templist[res.index(N)])            \n            for k in tempbooks:\n                final_books.append(sorted_books[price.index(k)])            \n            break\n            \n    return final_books\n        \nN = 18\nbooks = [(17,8), (9,4), (18,5), (11,9), (1,2), (13,7), (7,5), (3,6), (10,8)]\nprint(\"Best Combination: \",optimal_books(N,books))","visibility":"show","key":"xKnjiXLiq8"},{"type":"outputs","id":"ROkaw3UHTFHWHbU8DxvBn","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"(Price,Weight) details of books:  [(17, 8), (9, 4), (18, 5), (11, 9), (1, 2), (13, 7), (7, 5), (3, 6), (10, 8)]\nStore Credit:  18\nBest Combination:  [(1, 2), (17, 8)]\n"},"children":[],"key":"JkNMI3vbUW"}],"visibility":"show","key":"IPL9RFsacB"}],"visibility":"hide","key":"UERgIZSvgZ"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Problem: [WISH] Intersecting Lines","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"N9uDCRvPfx"}],"key":"n2qzcS7CNh"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Say you are given a list of tuples where the first element is the slope of a line and the second element is the y-intercept of a line.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"aADT7AdBcH"}],"key":"il3EKMqnPC"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Write a function find_intersecting to find which lines, if any, intersect with any of the others in the given x_range.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"aNrdxHjGjV"}],"key":"y9hHImywhF"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"strong","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Example Input","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"Oc6OH2XlRm"}],"key":"nHAFCDqYFX"}],"key":"NPpJS2UNJR"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"inlineCode","value":"tuple_list = [(2, 3), (-3, 5), (4, 6), (5, 7)] x_range = (0, 1)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"sANBw8wAiA"},{"type":"text","value":"\n","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"pN5KGxoppH"},{"type":"strong","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Output","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"rWIxpvz8Qq"}],"key":"WHjBsV3W3o"}],"key":"S22rmRUa9T"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"inlineCode","value":"def find_intersecting(tuple_list, x_range) ->  [(2,3), (-3,5)]","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"T1qF7w9FKe"}],"key":"PpTX4wRXfN"}],"class":"dropdown, tip","key":"e4NAZ4OPHA"}],"key":"K7lCRK3UCl"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# for 2 lines to intersect the formulas used here are:\n# y = mx + c\n# x = (c2-c1)/(m1-m2)\n# https://www.cuemath.com/geometry/intersection-of-two-lines/ Check this link for details of the formula\n\ndef intersectinglines(tuple_list,x_range):\n    output=[]\n    for i in range(len(tuple_list)):\n        for j in range(i+1,len(tuple_list)):\n\n            x = (tuple_list[j][1]-tuple_list[i][1])/(tuple_list[i][0]-tuple_list[j][0])\n            y = tuple_list[j][1]*x+tuple_list[j][0]\n\n            if x>=x_range[0] and x<=x_range[1]:\n                output.extend([tuple_list[i],tuple_list[j]])\n    return output\n\ntuple_list = [(2, 3), (-3, 5), (4, 6), (5, 7)]\nx_range = (0, 1)\n\nintersectinglines(tuple_list, x_range)","visibility":"show","key":"uMUedHxS8a"},{"type":"outputs","id":"h8O7oWr6WzX6ObtC5m7hd","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/plain":{"content":"[(2, 3), (-3, 5)]","content_type":"text/plain"}}},"children":[],"key":"BHIY0lTS4K"}],"visibility":"show","key":"lofnNrPtel"}],"visibility":"hide","key":"SItsk9466n"}],"key":"mzSYF0PNeq"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualization","url":"/visualization","group":"Story Telling"},"next":{"title":"Data Manipulation","url":"/data-manipulation","group":"Python"}}},"domain":"http://localhost:3000"}