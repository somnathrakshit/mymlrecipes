olumn":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"string_map(string1, string2) == True # as e’s get mapped to e even though there is two e","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"tknZUbtNuP"}],"key":"dIKPlze3U9"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"string1 = ‘enemy’\nstring2 = ‘yneme’","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"kddWFDko4M"}],"key":"Qk9k1G6L2k"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"string_map(string1, string2) == False # as e’s dont get mapped uniquely","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"a0GRjdTBjl"}],"key":"MnL9p5b5Q2"}],"class":"dropdown, tip","key":"Q3vg5FIRmu"}],"key":"K1N6ru6QnH"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"def string_map(string1, string2):    \n    if(string1==string2):\n        status = True\n    elif(len(string1)!=len(string2)):\n        status = False\n    else:\n        tempstore = {}\n        for i,j in enumerate(string1):\n            if(j in tempstore):               \n                if(tempstore[j] != string2[i]):\n                    status = False\n                    break\n            elif(string2[i] in tempstore.values()):\n                    status = False\n                    break\n            else:\n                tempstore[j] = string2[i]\n                status = True\n    return status\n\nprint(string_map('enemy', 'enemy'))\nprint(string_map('enemy', 'yneme'))\nprint(string_map('cat', 'ftt'))\nprint(string_map('ctt', 'fat'))\nprint(string_map('cat', 'fat'))","visibility":"show","key":"urqS8Ixo6r"},{"type":"outputs","id":"iMC9gT4Czb7r5tBdakJJO","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"True\nFalse\nFalse\nFalse\nTrue\n"},"children":[],"key":"JlP9kS6HwV"}],"visibility":"show","key":"F2FbZupP4R"}],"visibility":"hide","key":"fXrJII5Sfv"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Problem: [WORKDAY] Sorted String merge","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"B57oIwhrBr"}],"key":"wcu0uf0DBj"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Given two sorted lists, write a function to merge them into one sorted list.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"uMrJFXggPt"}],"key":"RjYZyjT0ZK"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"What’s the time complexity?","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"fsBRNLB7Kj"}],"key":"iyCZypA0Be"}],"class":"dropdown, tip","key":"k09l57c9CM"}],"key":"DOBgGpdyuq"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"def mergeArrays(arr1, arr2):\n    \n    n1 = len(arr1)\n    n2 = len(arr2)\n    arr3 = [None] * (n1 + n2)\n    i = 0\n    j = 0\n    k = 0\n    # Traverse both array\n    while i < n1 and j < n2:     \n        # Check if current element of first array is smaller than current element of second array. \n        # If yes, store first array element and increment first array index. Otherwise do same with second array\n        \n        if arr1[i] < arr2[j]:\n            arr3[k] = arr1[i]\n            k = k + 1\n            i = i + 1\n        else:\n            arr3[k] = arr2[j]\n            k = k + 1\n            j = j + 1\n     \n \n    # Store remaining elements\n    # of first array\n    while i < n1:\n        arr3[k] = arr1[i];\n        k = k + 1\n        i = i + 1\n \n    # Store remaining elements\n    # of second array\n    while j < n2:\n        arr3[k] = arr2[j];\n        k = k + 1\n        j = j + 1\n    print(\"Array after merging\")\n    for i in range(n1 + n2):\n        print(str(arr3[i]), end = \" \")\n \n\narr1 = [1, 3, 5, 7]\narr2 = [2, 4, 6, 8]\nmergeArrays(arr1, arr2)\n\n# Next coming to the time complexity it is linear as the execution time of the algorithm grows in direct proportion to the size of the data set it is processing.\n# For merging two arrays, we are always going to iterate through both of them no matter what, \n# so the number of iterations will always be m+n and the time complexity being O(m+n) where m = len(arr1) and n = len(arr2)","visibility":"show","key":"o4SPiABIM4"},{"type":"outputs","id":"aq_U-bn9YcLmVdX6Ujvdr","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Array after merging\n1 2 3 4 5 6 7 8 "},"children":[],"key":"i6Ni6TTl8O"}],"visibility":"show","key":"DdqATv0XaW"}],"visibility":"hide","key":"Vg3vNZCPXL"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Problem: [POSTMATES] Weekly Aggregation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"j5Kn4DntLw"}],"key":"kjpOGtzKRo"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Given a list of timestamps in sequential order, return a list of lists grouped by week (7 days) using the first timestamp as the starting point.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"XTCQ1gK0fM"}],"key":"wnrSyuHOBP"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"o6d2R4