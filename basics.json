 count of characters\n            if temp[i]%2==0:\n                even_count = even_count + 1\n            else:\n                odd_count = odd_count + 1\n        if((odd_count>1)or(even_count==0)):\n            return False\n        else:\n            return True    \n\nprint(palindrome_checker(\"carerac\"))\nprint(palindrome_checker(\"sunset\"))","visibility":"show","key":"m62EMIGatN"},{"type":"outputs","id":"DXvki0BiHf-QcHotZd5fw","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"True\nFalse\n"},"children":[],"key":"aXeqnTxyq9"}],"visibility":"show","key":"w1Vm5YwVZE"}],"visibility":"hide","key":"IdWhrq4SQC"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Problem: Pattern Generation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kQ5ETnlyM8"}],"key":"IbHqlYTiMf"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Write a function to generate this pattern:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"n19HtmHJyp"},{"type":"break","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YmE49AlFdA"},{"type":"text","value":"1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"D46G45a5Ox"},{"type":"break","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Wn9QybaB5l"},{"type":"text","value":"2 3","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nkrsI2eS7g"},{"type":"break","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"djhtYMTdD4"},{"type":"text","value":"4 5 6","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zFxcNLPJyD"}],"key":"qa1c3Hc6SV"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":11,"