hildren":[{"type":"text","value":"📖Explanation","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"CJORI4bGXd"}],"urlSource":"https://towardsdatascience.com/anomaly-detection-for-dummies-15f148e559c1","key":"AKdt2wRf9G"}],"key":"tdhq1roGVF"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Anomaly detection is the process of identifying unexpected items or events in data sets, which differ from the norm. And anomaly detection is often applied on unlabeled data which is known as unsupervised anomaly detection. Anomaly detection has two basic assumptions:","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"LMSDnsv0YS"}],"key":"gYQVfIbY01"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Anomalies only occur very rarely in the data.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"zijcZBZdT1"}],"key":"YoclNnBX9r"}],"key":"qiEv8bu9SM"},{"type":"listItem","spread":true,"position":{"start":{"line":28,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Their features differ from the normal instances significantly.","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"VsQIb69Hm5"}],"key":"EIBr62OU6a"}],"key":"jwBb1nh0fN"}],"key":"b4Koes5yNj"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"For Univariate Analysis Isolation Forest can be used to detect outliers that returns the anomaly score of each sample. Isolation Forest is a tree-based model. In these trees, partitions are created by first randomly selecting a feature and then selecting a random split value between the minimum and maximum value of the selected feature.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"BVEVEscHWi"}],"key":"lFmpSeNPpT"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"In multivariate anomaly detection, outlier is a combined unusual score on at least two variables. For Multivariate Analysis multiple options are avaliable other than isolation forest:","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"SE5tbx1DLo"}],"key":"TlPtlu2qil"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":34,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":34,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"The Cluster-based Local Outlier Factor (CBLOF) calculates the outlier score based on cluster-based local outlier factor. An anomaly score is computed by the distance of each instance to its cluster center multiplied by the instances belonging to its cluster.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"zv0WzHXmsG"}],"key":"FIa53UloTL"}],"key":"xVGDw89Hez"},{"type":"listItem","spread":true,"position":{"start":{"line":36,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Histogram-based Outlier Detection (HBOS) assumes the feature independence and calculates the degree of anomalies by building histograms. In multivariate anomaly detection, a histogram for each single feature can be computed, scored individually and combined at the end.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"tb3dEncgr4"}],"key":"wjJCvuNoyt"}],"key":"BvnHt2gXln"},{"type":"listItem","spread":true,"position":{"start":{"line":38,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"KNN is one of the simplest methods in anomaly detection. For a data point, its distance to its kth nearest neighbor could be viewed as the outlier score.","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"CoXcuw8O0i"}],"key":"cdtcdj1gkZ"}],"key":"zGp1m03Sj3"}],"key":"LtyIjdxHn3"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"An ensemble of these methods can be used to finalize the anamolies. Always visually investigate some of the anomalies.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"caMv1MPspF"}],"key":"Xv0tuwAs15"}],"class":"dropdown","key":"WjJ7DKEGAN"}],"key":"XL2Ne1AaCq"}],"key":"GONUQFFqTe"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Time Series Analysis","url":"/time-series-analysis","group":"Algorithms"},"next":{"title":"Neural Network","url":"/neural-network","group":"Neural Network"}}},"domain":"http://localhost:3000"}