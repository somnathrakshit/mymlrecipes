{"version":3,"kind":"Article","sha256":"d2b37530bcc3cd5476d0d6d9d433467b530946093fbf44a2bb83b7d34cfb5b40","slug":"industry-application","location":"/contents/Analytical Thinking/Industry Application.md","dependencies":[],"frontmatter":{"title":"Industry Application","content_includes_title":true,"authors":[{"nameParsed":{"literal":"Somnath Rakshit","given":"Somnath","family":"Rakshit"},"name":"Somnath Rakshit","email":"somnath52@gmail.com","id":"contributors-myst-generated-uid-0","corresponding":true}],"license":{"content":{"id":"MIT","url":"https://opensource.org/licenses/MIT","name":"MIT License","free":true,"osi":true}},"github":"https://github.com/somnathrakshit/mymlrecipes","numbering":{"title":{"offset":1}},"source_url":"https://github.com/somnathrakshit/mymlrecipes/blob/main/contents/Analytical Thinking/Industry Application.md","edit_url":"https://github.com/somnathrakshit/mymlrecipes/edit/main/contents/Analytical Thinking/Industry Application.md","exports":[{"format":"md","filename":"Industry Application.md","url":"/build/Industry Application-77f94d8a251a842310abc941e85e8e41.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":1,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Industry Application","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"OgpSqdU2uq"}],"identifier":"industry-application","label":"Industry Application","html_id":"industry-application","implicit":true,"key":"S8fR9JBpbg"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Zillow","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"VyXA7ziJU6"}],"key":"NosoBTJEgT"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Zillow’s rise and fall is a classic casestudy on both what to do and what not to do with data scien