":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"Core point:","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"nfYnKQGbKr"}],"key":"EPL9HIiv6Y"},{"type":"text","value":" A is a core point if its neighborhood (defined by ","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"n88VxJh4jK"},{"type":"inlineMath","value":"\\epsilon","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>ϵ</mi></mrow><annotation encoding=\"application/x-tex\">\\epsilon</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">ϵ</span></span></span></span>","key":"x9kbyvC9NS"},{"type":"text","value":") contains at least the same number or more points than the parameter MinPts.","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"taE6GzJuLG"}],"key":"TUe7CLQMlR"}],"key":"Kbivdqpwuw"},{"type":"listItem","spread":true,"position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"children":[{"type":"text","value":"Border point:","position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"key":"D0Ac7lRXTN"}],"key":"mIuDDrsQKj"},{"type":"text","value":" C is a border point that lies in a cluster and its neighborhood does not contain more points than MinPts, but it is still ‘density reachable’ by other points in the cluster.","position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"key":"u0WT9FScOE"}],"key":"ZX7TtCv5vj"}],"key":"GveobCStfl"},{"type":"listItem","spread":true,"position":{"start":{"line":61,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"Outlier:","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"zxBKn5m6L5"}],"key":"BwE3Mnd6nh"},{"type":"text","value":" N is an outlier point that lies in no cluster and it is not ‘density reachable’ nor ‘density connected’ to any other point. Thus this point will have “his own cluster”.","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"Sahsp8MZr7"}],"key":"ot8m8Yl09e"}],"key":"IckbtPafVM"}],"key":"sKkHYGj9Bm"}],"key":"C1cfZl9Tr1"}],"key":"j1Iip1BZx0"},{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"It is an unsupervised model and needs to be re-calibrated each time a new batch of data is analyzed.","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"T7i1UMo5U9"}],"key":"kDr7CFVOgn"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/image5-a1a678c20f6a82c289df0cbb34605df2.png","key":"BoTKvntNws","urlSource":"images/image5.png"}],"label":"image5","identifier":"image5","enumerator":"5","html_id":"image5","key":"c5m3RvFzjQ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":72,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":72,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Isolation Forests:","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"tykf7Cn1lO"}],"key":"ekbUiKyVf6"},{"type":"text","value":" Isolation forests are an effective method for detecting outliers or novelties in data. The basic principle is that outliers are few and far from the rest of the observations. To build a tree (training), the algorithm randomly picks a feature from the feature space and a random split value ranging between the maximums and minimums. This is made for all the observations in the training set. To build the forest a tree ensemble is made averaging all the trees in the forest.","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"dYILCe5Qmo"}],"key":"WYN6yH8Ua6"}],"key":"pOA38RlpwY"}],"key":"aHmMObo7Fa"},{"type":"paragraph","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Then for prediction, it compares an observation against that splitting value in a “node”, that node will have two node children on which another random comparisons will be made. The number of “splittings” made by the algorithm for an instance is named: “path length”. As expected, outliers will have shorter path lengths than the rest of the observations.","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"Riv1PASsM3"}],"key":"vkWXpIz3nC"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"If not correctly optimized, training time can be very long and computationally expensive.","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"CQw0aAga6J"}],"key":"TaLblkW7aI"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/image6-bd9d94178de5a062750cfa33fd48fc5c.png","key":"mhSQuQC9EK","urlSource":"images/image6.png"}],"label":"image6","identifier":"image6","enumerator":"6","html_id":"image6","key":"UXiYWzMFl3"},{"type":"heading","depth":2,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Dealing with Outliers","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"awOVLb9liX"}],"identifier":"dealing-with-outliers","label":"Dealing with Outliers","html_id":"dealing-with-outliers","implicit":true,"key":"M9cNLYGrxS"},{"type":"paragraph","position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"children":[{"type":"text","value":"Below are a few common practices to deal with Outliers:","position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"key":"sDBGd6En6u"}],"key":"NiloFHjMLP"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":89,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Drop the outlier records","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"EWVaHdC3Kf"}],"key":"ix5fqNvSOM"}],"key":"wZ8aKGA3Dt"},{"type":"listItem","spread":true,"position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Cap your outliers data or even you can try binning them","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"WvvnjHKRbT"}],"key":"kesUT7y6O4"}],"key":"pUoeqWzAQ6"},{"type":"listItem","spread":true,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Assign a new value: If an outlier seems to be due to a mistake in the data, you try imputing a value. Common imputation methods include using the mean of a variable or utilizing a regression model to predict the missing value","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"vBO2qrJD3W"}],"key":"FG46H6lY5g"}],"key":"lDsCP65JSL"},{"type":"listItem","spread":true,"position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Try a transformation: A different approach to true outliers could be to try creating a transformation of the data rather than using the data itself. For example, try creating a percentile version of your original field and working with that new field instead.","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"H9piMtpRCc"}],"key":"fC0QJ6tptG"}],"key":"ldO6IlNCzo"}],"key":"NpS612mB9p"}],"key":"X1FWE1lfF1"}],"key":"AQYAkO5uBH"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Missing Value","url":"/missing-value","group":"Model Building"},"next":{"title":"Hyperparameter Optimization","url":"/hyperparameter-optimization","group":"Model Building"}}},"domain":"http://localhost:3000"}